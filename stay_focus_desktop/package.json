{
  "name": "stay-focus-desktop",
  "version": "2.5.3",
  "author": "EarthPlayer1935",
  "description": "Stay Focus desktop application with click-through masking",
  "repository": "EarthPlayer1935/Stay_focus",
  "main": "main/index.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win",
    "dist:mac": "electron-builder --mac"
  },
  "devDependencies": {
    "electron": "^29.1.5",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.stayfocus.desktop",
    "productName": "Stay Focus",
    "directories": {
      "output": "dist"
    },
    "publish": [
      {
        "provider": "github"
      }
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "assets/icon.png",
      "category": "public.app-category.productivity",
      "artifactName": "Stay-Focus-${version}.${ext}"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "artifactName": "Stay-Focus-Setup-${version}.${ext}"
    },
    "nsis": {
      "unicode": true,
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "extraResources": [
      {
        "from": "../stay_focus_extension/_locales",
        "to": "_locales",
        "filter": ["**/*"]
      }
    ]
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}
